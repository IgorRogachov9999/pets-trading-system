# API base URL — used by the Vite dev proxy and production CloudFront routing.
# In development this is left empty (Vite proxies /api → localhost:8080).
# In production set to the CloudFront distribution URL.
VITE_API_BASE_URL=

# WebSocket endpoint for API Gateway (production only)
VITE_WS_URL=wss://your-api-gateway-id.execute-api.your-region.amazonaws.com/prod

# Amazon Cognito configuration
VITE_COGNITO_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
