  ],
  "mcpServers": [
    {
      "name": "atlassian",
      "transport": "docker",
      "image": "mcp/atlassian",
      "env": {
        "CONFLUENCE_URL": "$CONFLUENCE_URL",
        "CONFLUENCE_USERNAME": "$ATLASSIAN_USERNAME",
        "CONFLUENCE_API_TOKEN": "$ATLASSIAN_TOKEN",
        "JIRA_URL": "$JIRA_URL",
        "JIRA_USERNAME": "$ATLASSIAN_USERNAME",
        "JIRA_API_TOKEN": "$ATLASSIAN_TOKEN"
      }
    },
    {
      "name": "zephyr",
      "transport": "npx",
      "package": "@smartbear/mcp",
      "env": {
        "ZEPHYR_API_TOKEN": "$ZEPHYR_API_TOKEN",
        "JIRA_BASE_URL": "$JIRA_URL"
      }
    },
    {
      "name": "aws-documentation",
      "transport": "docker",
      "image": "mcp/aws-documentation"
    },
    {
      "name": "github",
      "transport": "docker",
      "image": "ghcr.io/github/github-mcp-server",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "$GITHUB_PERSONAL_ACCESS_TOKEN"
      }
    },
    {
      "name": "microsoft-docs",
      "transport": "http",
      "url": "https://learn.microsoft.com/api/mcp"
    },
    {
      "name": "aws-terraform",
      "transport": "docker",
      "image": "mcp/aws-terraform"
    },
    {
      "name": "aws-core",
      "transport": "uvx",
      "package": "awslabs.core-mcp-server@latest"
    }
  ],
  "agents": [
    {
      "name": "solution-architect",
      "path": ".claude/agents/solution-architect.md"
    },
    {
      "name": "ui-ux-designer",
